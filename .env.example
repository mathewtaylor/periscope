# Periscope configuration — copy to .env to override.
# All values are optional; defaults are listed below.

# ── Server (API + WS + static SPA) ─────────────────────────────────────
# Container-internal port the Bun server listens on.
PORT=5050

# Host-side port Docker maps to the container's PORT. Only used by
# docker-compose.yml. Change if 5050 is busy on the host.
PERISCOPE_HOST_PORT=5050

# Where SQLite writes. In Docker the named volume mounts at /data.
DB_PATH=./data/events.db

# Path to the built Vue SPA. The server runs API-only if this is missing.
WEB_DIST=./web/dist

# ── Dev-only: Vite dashboard with HMR ──────────────────────────────────
# Port the Vite dev server binds to (bun run dev:web).
WEB_PORT=5173

# Backend URL Vite should proxy /api and /ws to. Usually matches PORT.
API_URL=http://localhost:5050

# ── Client-side (periscope-relay.ts) ───────────────────────────────────
# Target collector URL — set on every machine running Claude Code.
# PERISCOPE_URL=http://localhost:5050
